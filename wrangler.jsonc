{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "estroni-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2024-10-22",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "vars": {
    "STOREFRONT_ORIGIN": "https://estroni.com.au",
    "SERVER_NAME": "io.github.estroni/storefront",
    "SERVER_VERSION": "1.0.0"
  }
}
